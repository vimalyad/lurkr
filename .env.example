# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.
# All of these are read by the BACKEND (server/index.mjs), not the frontend.

# ── Core (intelligence pipeline) ────────────────────────────────────────────────
# OpenRouter — all LLM calls (discovery, analysts, strategy). https://openrouter.ai
OPENROUTER_API_KEY="sk-or-..."

# Tavily — live web-search signals during gather. Free tier at https://tavily.com
TAVILY_API_KEY="tvly-..."

# ── Persistence + auth (required for accounts) ──────────────────────────────────
# Neon (Postgres) connection string. Auth + saved ideas require this. https://neon.tech
DATABASE_URL="postgresql://..."

# Secret for signing session JWTs. Generate: openssl rand -hex 32
JWT_SECRET="<64-hex-chars>"

# ── Google sign-in ──────────────────────────────────────────────────────────────
# OAuth 2.0 Web client ID from Google Cloud Console (no secret needed — we verify
# the ID token). Add your origins to "Authorized JavaScript origins":
#   https://vimalyad.github.io  and  http://localhost:5173
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"

# ── Email (verification + password reset) via Resend ────────────────────────────
# https://resend.com — without this, links are logged to the server console instead.
RESEND_API_KEY="re_..."
RESEND_FROM="Lurkr <onboarding@resend.dev>"   # use a verified-domain sender in prod

# Where email links point (the hosted frontend).
APP_URL="https://vimalyad.github.io/lurkr/"

# ── Daily-refresh cron ───────────────────────────────────────────────────────────
# Shared secret the GitHub Actions schedule sends in X-Cron-Secret. Must match the
# CRON_SECRET stored in the repo's GitHub Secrets. Generate: openssl rand -hex 32
CRON_SECRET="<64-hex-chars>"

# ── Frontend build-time (NOT read here; set in CI / build env) ──────────────────
# VITE_API_URL            — backend base URL baked into the frontend build
# VITE_GOOGLE_CLIENT_ID   — same Google client ID, exposed to the browser for the button
